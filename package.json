{
  "name": "n8n-nodes-mailvalid",
  "version": "0.1.3",
  "description": "n8n community node for MailValid — real-time and bulk email verification (syntax, MX, SMTP, disposable and role-based detection)",
  "keywords": [
    "n8n-community-node-package",
    "email-verification",
    "email-validation",
    "mailvalid",
    "disposable-email",
    "smtp-check"
  ],
  "license": "MIT",
  "homepage": "https://mailvalid.io",
  "author": {
    "name": "MailValid",
    "email": "sachin@mailvalid.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/techorigins/n8n-nodes-mailvalid.git"
  },
  "bugs": {
    "url": "https://github.com/techorigins/n8n-nodes-mailvalid/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/MailValidApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/MailValid/MailValid.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "release-it": "20.2.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
