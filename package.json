{
  "name": "n8n-nodes-mailvalid",
  "version": "0.1.0",
  "description": "n8n community node for MailValid — real-time and bulk email verification (syntax, MX, SMTP, disposable and role-based detection)",
  "keywords": [
    "n8n-community-node-package",
    "email-verification",
    "email-validation",
    "mailvalid",
    "disposable-email",
    "smtp-check"
  ],
  "license": "MIT",
  "homepage": "https://mailvalid.io",
  "author": {
    "name": "MailValid",
    "email": "sachin@mailvalid.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/techorigins/n8n-nodes-mailvalid.git"
  },
  "bugs": {
    "url": "https://github.com/techorigins/n8n-nodes-mailvalid/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "dev": "tsc --watch",
    "lint": "eslint nodes credentials",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/MailValidApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/MailValid/MailValid.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.7",
    "n8n-workflow": "^1.48.0",
    "typescript": "^5.5.4"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
